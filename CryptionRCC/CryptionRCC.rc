/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// 最小 ID 值的圖示位於最前，確保應用程式圖示
// 在所有系統上都保持一致。
IDR_MAINFRAME           ICON                    "..\\res\\Icon_Tool.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOGEX 0, 0, 235, 55
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | 
    WS_SYSMENU
CAPTION "關於 CryptionRCC"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,17,21,20
    LTEXT           "CryptionRCC 版本 1.0",IDC_STATIC,40,10,119,8,
                    SS_NOPREFIX
    LTEXT           "版權所有 (C) 2010 ",IDC_STATIC,40,25,169,8
    DEFPUSHBUTTON   "確定",IDOK,178,7,50,16,WS_GROUP
END

IDD_CRYPTIONRCC_DIALOG DIALOGEX 0, 0, 389, 392
STYLE DS_SETFONT | DS_MODALFRAME | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | 
    WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "CryptionRCC"
FONT 8, "Tahoma", 400, 0, 0x0
BEGIN
    EDITTEXT        IDC_EDIT1,100,333,271,14,ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "開啟",IDC_BUTTON1,44,332,50,14
    LTEXT           "輸入",IDC_STATIC,14,334,18,8
    EDITTEXT        IDC_EDIT2,100,350,271,14,ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "儲存",IDC_BUTTON2,44,349,50,14
    LTEXT           "輸出",IDC_STATIC,14,351,24,8
    PUSHBUTTON      "加密",IDC_BUTTON3,162,369,50,14
    PUSHBUTTON      "解密",IDC_BUTTON4,218,369,50,14
    PUSHBUTTON      "交換",IDC_BUTTON5,328,369,50,14
    COMBOBOX        IDC_COMBO1,87,369,70,106,CBS_DROPDOWNLIST | 
                    CBS_AUTOHSCROLL | CBS_SORT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "複製相同值",IDC_BUTTON6,274,369,50,14
    COMBOBOX        IDC_MODCRYPTION,13,369,70,124,CBS_DROPDOWNLIST | 
                    CBS_SORT | WS_VSCROLL | WS_TABSTOP
    EDITTEXT        IDC_EDIT_STATIC,4,8,377,317,ES_MULTILINE | 
                    ES_AUTOHSCROLL | ES_READONLY | WS_VSCROLL
END


